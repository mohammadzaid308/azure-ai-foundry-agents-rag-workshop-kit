<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
    <add key="azure-sdk-dev" value="https://pkgs.dev.azure.com/azure-sdk/public/_packaging/azure-sdk-for-net/nuget/v3/index.json" protocolVersion="3" />
  </packageSources>
  <packageSourceMapping>
    <!-- Everything resolves from nuget.org... -->
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
    <!-- ...except the preview Azure AI Projects packages, which come from the dev feed. -->
    <packageSource key="azure-sdk-dev">
      <package pattern="Azure.AI.Projects*" />
      <package pattern="Azure.AI.Extensions.OpenAI*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
