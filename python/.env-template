# Core (required for every lab)
FOUNDRY_PROJECT_ENDPOINT=https://<YOUR-RESOURCE>.services.ai.azure.com/api/projects/<YOUR-PROJECT>
FOUNDRY_AGENT_NAME=workshop-agent
FOUNDRY_MODEL_DEPLOYMENT=gpt-4o

# Lab 3 grounding (only needed for the grounding labs)
FOUNDRY_BING_CONNECTION_ID=
FOUNDRY_SEARCH_CONNECTION_NAME=
FOUNDRY_SEARCH_INDEX_NAME=workshop-index

# Lab 5 observability (optional)
APPLICATIONINSIGHTS_CONNECTION_STRING=

# Lab 4 multi-agent workflow name (optional; defaults to bakery-support-workflow)
FOUNDRY_WORKFLOW_NAME=bakery-support-workflow

# Lab 5 evaluations (Python agent/traces scenarios only; dataset scenario needs none)
FOUNDRY_AGENT_ID=bakery-agent:1
